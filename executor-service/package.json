{
  "name": "executor-service",
  "version": "1.0.0",
  "description": "Sandboxed code execution engine with Docker container isolation",
  "main": "src/index.ts",
  "scripts": {
    "build": "npx tsc",
    "watch": "npx tsc -w",
    "prestart": "npm run build",
    "start": "npx nodemon dist/index.js",
    "dev": "npx concurrently --kill-others \"npm run watch\" \"npm start\""
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/dockerode": "^3.3.30",
    "@types/express": "^4.17.21",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.16.0",
    "nodemon": "^3.1.4",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@bull-board/express": "^5.21.0",
    "bullmq": "^5.9.0",
    "concurrently": "^8.2.2",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "keywords": [
    "code-execution",
    "docker-sandbox",
    "REST",
    "expressjs",
    "bullmq",
    "dockerode",
    "microservice",
    "queue",
    "nodejs"
  ]
}
