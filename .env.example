# ========================================
# CodeForge — Environment Configuration
# ========================================
# Copy this file to .env and fill in values

# --- Problem Service ---
PROBLEM_SERVICE_PORT=3000
MONGODB_URL=mongodb://admin:password@localhost:27017/codejudge?authSource=admin

# --- Submission Service ---
SUBMISSION_SERVICE_PORT=4000
PG_HOST=localhost
PG_PORT=5432
PG_USER=codejudge
PG_PASSWORD=codejudge_pass
PG_DATABASE=codejudge_db
PROBLEM_SERVICE_BASE_URL=http://localhost:3000
SOCKET_SERVICE_URL=http://localhost:5001
JWT_SECRET=your_strong_jwt_secret_key_here

# --- Executor Service ---
EXECUTOR_SERVICE_PORT=7000

# --- Gateway (Socket) Service ---
GATEWAY_SERVICE_PORT=5001

# --- Redis (shared) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# --- Frontend ---
VITE_API_BASE=http://localhost:4000
VITE_PROBLEM_API=http://localhost:3000
VITE_SOCKET_URL=http://localhost:5001

# --- General ---
NODE_ENV=development
